# Copy to .env and fill in. .env is gitignored.

# Ordnance Survey Data Hub project API key (https://osdatahub.os.uk/ -> create API project)
# Needed for OS Maps basemap tiles and OS NGD Features (building/land polygons).
OS_API_KEY=

# Microsoft Planetary Computer needs no key for browsing; the `planetary-computer`
# package signs asset URLs automatically. A subscription key raises rate limits (optional).
PC_SDK_SUBSCRIPTION_KEY=
